{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    // Type-check only: the villager is executed by `tsx`, not emitted by `tsc`.
    "noEmit": true
  },
  // The villager mind speaks only the bus contract (villager <-> engine), so it
  // includes shared/ and bus/ — but never the client wire types.
  "include": ["src/**/*.ts", "../shared/**/*.ts", "../bus/**/*.ts"]
}
