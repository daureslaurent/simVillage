# ---------------------------------------------------------------------------
# Copy to `.env` (docker compose reads it automatically). Values below are the
# defaults baked into docker-compose.yml; override here per-environment.
# ---------------------------------------------------------------------------

# MongoDB connection string used by the backend container.
# Host is the compose service name `mongo`.
MONGO_URL=mongodb://mongo:27017/simvillage

# Where the backend reaches the shared LLM engine (the `llm` service), and how
# long it waits for an answer before a mind skips its turn.
LLM_URL=http://llm:8090
LLM_CLIENT_TIMEOUT_MS=120000

# Port the backend's browser-facing WebSocket server listens on (inside the
# container AND mapped to the host). This is what the browser connects to.
GATEWAY_WS_PORT=8080

# How often (in ticks) the engine persists a world snapshot to Mongo.
SNAPSHOT_EVERY_TICKS=50

# World simulation rate (ticks/second). Minds think on one shared llama server,
# so the clock is slowed from its 10/s default to let villagers stay near each
# other long enough to interact between thoughts.
WORLD_TICK_RATE=3

# Master TIME-SCALE for the WHOLE simulation. >1 runs everything faster in lock-step
# (movement, the in-world clock, needs/economy/weather, and how often minds think),
# without changing the world's internal proportions. 1 = normal, 2 = twice as fast,
# 0.5 = half speed. Clamped to [0.1, 20]. (Note: minds still have a hard LLM-latency
# floor, so very high speeds mostly accelerate movement + the clock, not thinking.)
SIM_SPEED=1

# Browser-facing WebSocket URL baked into the client bundle at BUILD time.
# LEAVE EMPTY for normal deployments: the bundle then talks to its OWN origin
# (the page's host:port), which nginx reverse-proxies to the backend. Setting it
# to ws://localhost:8080 here would bake "localhost" into the bundle, so visitors
# on a remote server (e.g. a VPS) would try to reach their OWN machine and fail.
# Only set this to point the browser directly at some other gateway host.
# (Local dev hot-reload uses docker-compose.dev.yml, which defaults this itself.)
VITE_WS_URL=

# ---------------------------------------------------------------------------
# The single LLM engine (`llm` service) — the ONE thing that talks to llama.
# The backend POSTs all its LLM work here (over LLM_URL), and the engine
# serializes it so the lone server is never hit concurrently. These vars live
# ONLY on the engine.
# ---------------------------------------------------------------------------

# Port the engine's HTTP server listens on (and is mapped to the host).
LLM_PORT=8090

# The OpenAI-compatible llama server (POST {url}/v1/chat/completions). Comma-
# separate to pool several for failover; a single URL is the norm. From inside
# Docker, reach a host-run server via host.docker.internal.
LLAMA_URLS=http://host.docker.internal:8080
# Model tag the server expects (many single-model llama servers ignore this).
LLAMA_MODEL=llama
# Optional bearer token, only if your server requires auth.
LLAMA_API_KEY=
# Per-request timeout (ms) before failing over to the next server.
LLAMA_TIMEOUT_MS=30000
# Log every LLM round-trip (prompt sent + raw response + latency). Verbose;
# leave off unless debugging what the model is actually seeing/returning.
LLAMA_DEBUG=0
# Optional floor on the gap between successive llama calls (ms; 0 = none). Raise
# it to give a slow single server breathing room between requests.
LLM_ENGINE_MIN_GAP_MS=0
# Global cap on completion length (tokens) for EVERY llama call — villager
# decisions AND reflection/planning prose. Empty = no cap on decisions, and the
# 1024 default for prose. Raise it for a THINKING/reasoning model that spends
# tokens deliberating before it answers (too tight a cap and it never reaches its
# output). A value like 4096 is a safe headroom for such models.
LLM_MAX_TOKENS=
# Prose-only override (reflection/planning); falls back to LLM_MAX_TOKENS then 1024.
LLAMA_SYNTH_MAX_TOKENS=

# Anti-repetition sampling — sent on EVERY llama call. A local model with no
# repetition penalty can fall into a degenerate loop (the same phrase repeated
# until max_tokens), so a mild penalty is always applied. Set a penalty to its
# neutral value to disable it.
#   LLM_REPEAT_PENALTY  — llama.cpp's repeat penalty; 1.0 = off, ~1.1 is mild,
#     higher bites harder (too high can hurt valid JSON tool output).
#   LLM_REPEAT_LAST_N   — how many recent tokens that penalty looks back over.
#   LLM_FREQUENCY_PENALTY / LLM_PRESENCE_PENALTY — OpenAI-standard penalties
#     (also honoured by llama.cpp); 0 = off.
LLM_REPEAT_PENALTY=1.1
LLM_REPEAT_LAST_N=256
LLM_FREQUENCY_PENALTY=0.3
LLM_PRESENCE_PENALTY=0
# Stream loop-detector (safety net beyond the penalties): cut a streamed response
# short the moment its tail becomes the same block repeated N times in a row.
#   LLM_LOOP_GUARD          — on by default; set off/0/false/no to disable.
#   LLM_LOOP_GUARD_REPEATS  — verbatim back-to-back repeats before the cut (min 2).
LLM_LOOP_GUARD=on
LLM_LOOP_GUARD_REPEATS=4

# Agentic loop budgets. Each granted turn now runs a multi-step loop: a mind may
# call read-only LOOKUP tools (map / memories / building_guide / construction /
# look_at), take one or more world actions, then yield.
#   MIND_MAX_READS — how many lookups a villager may make in one turn before it is
#     told to act on what it knows (bounds LLM cost across many parallel minds).
#   MIND_MAX_STEPS — hard cap on TOTAL assistant turns in the loop (a safety net so
#     a confused model can't loop forever); must comfortably exceed MIND_MAX_READS.
#   SUPERVISOR_MAX_STEPS — the God Agent's equivalent step cap (it has no lookups,
#     so this only bounds how many divine acts it may chain in one deliberation).
MIND_MAX_READS=3
MIND_MAX_STEPS=8
SUPERVISOR_MAX_STEPS=4

# Embedding server for memory (POST {url}/v1/embeddings). The bundled `embed`
# service (llama.cpp CUDA, see docker-compose.yml) serves this on the compose
# network; EMBED_MODEL must match that server's --alias. Leave blank only if you
# have a separate embedding fleet and want to fall back to LLAMA_URLS.
EMBED_URLS=http://embed:8080
EMBED_MODEL=nomic-embed-text
# Vector size the embedding model emits. The villager pins its memory collection to
# this, so the villager's EMBED_DIM MUST match the engine's.
EMBED_DIM=768

# ---------------------------------------------------------------------------
# Villagers — the minds, all run inside the backend (one process drives them).
# ---------------------------------------------------------------------------

# WORLD CREATION. When no world exists yet, the FRONTEND shows a first-run setup
# screen: choose auto-generate (LLM) with a free-text STYLE (desert, alien, water…),
# a villager count and a size — or the classic hand-crafted village. The result is
# persisted; later boots resume it. A "New Village" button in Settings wipes it and
# returns to setup.
#   GENERATE_LLM  — whether the auto-generate option is offered at all.
GENERATE_LLM=on
#   GENERATE_AUTO — skip the setup screen and auto-generate HEADLESSLY with the env
#                   style/count below (for dev/CI with no browser). Empty = off.
GENERATE_AUTO=
#   GENERATE_THEME — prefills the style field (and is the headless style). Empty lets
#                    the model invent one. Only NAMES, colours, flavour and layout
#                    change — the economy/tools stay fixed, so the village is playable.
GENERATE_THEME=
#   MAX_GENERATE_VILLAGERS — the villager-count ceiling (the setup slider's max).
MAX_GENERATE_VILLAGERS=6

# Which bodies get minds. VILLAGER_IDS (comma-separated) wins; otherwise
# villager_1..VILLAGER_COUNT. Keep VILLAGER_COUNT equal to the world seed's
# villager count so every body has a mind. (Ignored when GENERATE_LLM=on: the
# generated roster decides who exists.)
# VILLAGER_IDS=villager_1,villager_2,villager_3
VILLAGER_COUNT=5

# Optional per-villager personas, as a JSON object keyed by id. This is the way
# to give each villager a distinct character; ids absent here use a default.
# VILLAGER_PROFILES={"villager_1":{"name":"Bram the Baker","traits":["curious","talkative"],"goal":"Find someone to share fresh bread with."}}

# Sensory radius (tiles) and the gap between a mind's LLM decisions (ms). The
# cadence is calm because one shared server thinks for every mind, and slower
# thinking leaves time for villagers to react to one another.
VILLAGER_SENSE_RADIUS=8
VILLAGER_THINK_INTERVAL_MS=12000

# Long-term memory (RAG). On by default when running via docker compose (the
# qdrant service is already in docker-compose.yml). Set to "off" to disable.
VILLAGER_MEMORY=on
QDRANT_URL=http://qdrant:6333

# --- Recall tuning (optional; sensible defaults baked in) ---
# Recall over-fetches RECALL_CANDIDATE_MULTIPLIER × topK nearest by cosine, then
# re-ranks them by relevance × recency × importance and keeps the top few. This is
# what lets a planted idea / recent reflection surface instead of pure cosine
# proximity. Set the multiplier to 1 to disable re-ranking (pure cosine).
RECALL_CANDIDATE_MULTIPLIER=4
RECALL_W_RELEVANCE=1.0
RECALL_W_RECENCY=0.5
RECALL_W_IMPORTANCE=1.0
# A stationary villager emits the same situation query every turn; recall is
# memoized for this many ms (any new memory busts it immediately). 0 disables.
RECALL_CACHE_TTL_MS=30000
# Most `conversation` memories allowed in one recall result. Group speech is
# abundant and self-similar, so without a cap it floods recall and the mind just
# echoes the chatter back (the talk-loop). Capping leaves room for the villager's
# own reasoning, facts, and reflections. 0 disables the cap.
RECALL_CONVERSATION_CAP=2
